# =============================================================
# XynPOS Backend — Environment Variables Template
# Copy to .env and fill in your values
# NEVER commit .env to version control
# =============================================================

# ── Application ──────────────────────────────────────────────
APP_ENV=development                          # development | staging | production
APP_LOG_LEVEL=debug                          # debug | info | warn | error

# ── Database (PostgreSQL 18 via PgBouncer) ───────────────────
DATABASE_URL=postgres://xynpos:dev_password@localhost:5433/xynpos?sslmode=disable
DATABASE_MAX_CONNS=25
DATABASE_MIN_CONNS=5

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://:dev_redis_password@localhost:6379/0
REDIS_PASSWORD=dev_redis_password
REDIS_DB=0

# ── NATS JetStream ───────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── JWT ──────────────────────────────────────────────────────
# IMPORTANT: Use strong random secrets in production!
# Generate: openssl rand -base64 64
JWT_ACCESS_SECRET=CHANGE_ME_IN_PRODUCTION_MINIMUM_64_CHARACTERS_LONG_RANDOM_STRING_HERE
JWT_REFRESH_SECRET=CHANGE_ME_IN_PRODUCTION_DIFFERENT_FROM_ACCESS_SECRET_ALSO_RANDOM
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=720h
JWT_ISSUER=xynpos.com

# ── Storage (MinIO local / Cloudflare R2 production) ─────────
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin123
STORAGE_BUCKET=xynpos-media
STORAGE_PUBLIC_URL=http://localhost:9000/xynpos-media
STORAGE_REGION=us-east-1
STORAGE_USE_SSL=false

# Production (Cloudflare R2):
# STORAGE_PROVIDER=r2
# STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# STORAGE_ACCESS_KEY_ID=<r2-access-key>
# STORAGE_SECRET_ACCESS_KEY=<r2-secret-key>
# STORAGE_BUCKET=xynpos-media-prod
# STORAGE_PUBLIC_URL=https://media.xynpos.com
# STORAGE_REGION=auto
# STORAGE_USE_SSL=true

# ── Email (Resend) ───────────────────────────────────────────
EMAIL_PROVIDER=mock         # mock | resend (use mock in development)
RESEND_API_KEY=            # re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=XynPOS <noreply@xynpos.com>

# ── Firebase FCM (Mobile Push) ───────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_JSON=   # JSON string or path to credentials file

# ── Observability ────────────────────────────────────────────
TRACER_ENABLED=true
JAEGER_OTLP_URL=localhost:4317    # Start with: docker-compose --profile monitoring up -d

# ── Payment Gateways ─────────────────────────────────────────
XENDIT_SECRET_KEY=            # xnd_xxxxxx
XENDIT_WEBHOOK_TOKEN=         # From Xendit dashboard
MIDTRANS_SERVER_KEY=          # SB-Mid-server-xxxxxx (sandbox) or Mid-server-xxx (production)
MIDTRANS_CLIENT_KEY=          # SB-Mid-client-xxxxxx

# ── Meilisearch ──────────────────────────────────────────────
MEILISEARCH_URL=http://localhost:7700
MEILI_MASTER_KEY=dev_master_key_change_me

# ── Worker ───────────────────────────────────────────────────
WORKER_CONCURRENCY=10

# ── PostgreSQL direct (for migrations, not application) ──────
POSTGRES_PASSWORD=dev_password

# ── MinIO ────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# ── Grafana ──────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── gRPC addresses (service discovery) ──────────────────────
AUTH_GRPC_ADDR=localhost:9001
PRODUCT_GRPC_ADDR=localhost:9003
INVENTORY_GRPC_ADDR=localhost:9004
PAYMENT_GRPC_ADDR=localhost:9006
