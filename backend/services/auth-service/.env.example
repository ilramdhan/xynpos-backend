# XynPOS Auth Service — Environment Variables
# Copy this file to .env and fill in the values.
# .env is gitignored. Never commit real secrets.

# ── App ────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8001
APP_LOG_LEVEL=debug

# ── Database (PostgreSQL 18) ────────────────────────────────────
DATABASE_URL=postgres://xynpos:xynpos@localhost:5432/xynpos_auth?sslmode=disable
DATABASE_MAX_CONNS=25
DATABASE_MIN_CONNS=5

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_DB=0

# ── NATS JetStream ───────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── JWT ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_MIN_32_CHARS
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=720h
JWT_ISSUER=xynpos.com

# ── gRPC ─────────────────────────────────────────────────────────
GRPC_PORT=8002
TENANT_SERVICE_GRPC_ADDR=localhost:9001

# ── OpenTelemetry / Jaeger ───────────────────────────────────────
TRACER_ENABLED=false
JAEGER_OTLP_URL=http://localhost:14268/api/traces
