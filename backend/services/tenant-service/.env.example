# XynPOS Tenant Service — Environment Variables
# Copy this file to .env and fill in the values.

# ── App ────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=9000
APP_LOG_LEVEL=debug

# ── Database (PostgreSQL 18, multi-tenant schema-per-tenant) ────
DATABASE_URL=postgres://xynpos:xynpos@localhost:5432/xynpos_tenant?sslmode=disable
DATABASE_MAX_CONNS=25
DATABASE_MIN_CONNS=5

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/1
REDIS_PASSWORD=
REDIS_DB=1

# ── NATS JetStream ───────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── gRPC ─────────────────────────────────────────────────────────
GRPC_PORT=9001
AUTH_SERVICE_GRPC_ADDR=localhost:8002

# ── OpenTelemetry / Jaeger ───────────────────────────────────────
TRACER_ENABLED=false
JAEGER_OTLP_URL=http://localhost:14268/api/traces
