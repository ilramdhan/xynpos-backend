# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/
dist/

# Go build artifacts
*.test
*.out
coverage.out
coverage.html

# Environment files (NEVER commit secrets)
.env
.env.local
.env.*.local
*.env.local

# Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# RULE-CI-010: go.work.sum MUST be committed to git.
# Without it, CI cannot resolve cross-workspace dependencies (e.g. shared/proto/auth).
# Do NOT add go.work.sum to .gitignore.
# Regenerate with: go work sync

# Swagger generated
docs/swagger.json
docs/swagger.yaml
docs/docs.go

# Mock generated (auto-generated by mockery)
**/mock/*.go
**/mocks/*.go

# Protobuf generated (auto-generated)
**/*.pb.go
**/*_grpc.pb.go

# Docker
.docker/

# Terraform
infra/terraform/**/.terraform/
infra/terraform/**/terraform.tfstate
infra/terraform/**/terraform.tfstate.backup
infra/terraform/**/.terraform.lock.hcl
infra/terraform/**/terraform.tfvars

# Local dev overrides
docker-compose.override.yml

# Keystore (Android signing)
*.jks
*.keystore

# Firebase credentials
*firebase-credentials.json
*service-account.json

# Test artifacts
test-results/
junit-report.xml

# Air (live reload)
tmp/
